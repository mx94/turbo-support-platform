# ==========================================
# Turbo Support Platform
# 环境配置模板 (.env.example)
#
# 对于本地开发环境：
# 1. 复制此文件并重命名为 `.env.local`
# 2. 补齐 Supabase、Stream 和由于模型需要调用的 API Keys
# ==========================================

# -----------------
# 1. Supabase (必填)
# -----------------
# 这些值可以在你创建好 Supabase Web UI 的 Project / API Settings 里获取
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# 供后端 Server Actions 越权操作时使用 (千万不要以 NEXT_PUBLIC_ 暴露给前端)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"


# -----------------
# 2. Stream Chat (人工服务/群组通讯必填)
# -----------------
NEXT_PUBLIC_STREAM_KEY="your-stream-api-key"
STREAM_SECRET="your-stream-api-secret"


# -----------------
# 3. AI 语言模型配置 (智能助手必填)
# -----------------
# 默认为 OpenAI 兼容格式
# 在 packages/support 内您可以轻松将底座替换为 DeepSeek, Gemini 或自建底座
OPENAI_API_KEY="sk-your-llm-api-key"
# OPENAI_BASE_URL="https://api.openai.com/v1" # 根据你的 API 代理或服务商自定义


# -----------------
# 4. 其它业务配置 (可选)
# -----------------
# 管理员端站点的 URL（如果 Admin 端和 User 端异地部署的话可能需要设定跨域跳转）
# NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
